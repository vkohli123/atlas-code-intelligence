# Backend
ATLAS_ENV=local
ATLAS_API_KEY=dev-secret
ATLAS_REQUIRE_API_KEY=false
ATLAS_DATABASE_URL=postgresql+asyncpg://atlas:atlas@postgres:5432/atlas
ATLAS_REDIS_URL=redis://redis:6379/0
ATLAS_ALLOWED_ORIGINS=http://localhost:3000
ATLAS_EMBEDDING_PROVIDER=hash
ATLAS_EMBEDDING_DIM=384
ATLAS_LLM_PROVIDER=mock
ATLAS_OPENAI_MODEL=gpt-4o-mini
ATLAS_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Atlas
